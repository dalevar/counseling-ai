# ============================================================
# EduCouns AI — Frontend Environment Variables Template
# Salin file ini ke .env dan isi sesuai konfigurasi lokal Anda
# JANGAN commit file .env ke Git!
# ============================================================

# === API Backend ===
# URL base API backend. Ganti dengan URL production saat deploy.
VITE_API_URL=http://localhost:5001/api

# === Socket.IO ===
# URL server WebSocket untuk fitur realtime (chat, notifikasi)
VITE_SOCKET_URL=http://localhost:5001

# === Informasi Aplikasi ===
VITE_APP_NAME=EduCouns AI
VITE_APP_VERSION=1.0.0

# === Feature Flags ===
# Nonaktifkan fitur dengan nilai 'false' jika belum tersedia di backend
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_FORUM=true
VITE_ENABLE_ASSESSMENT=true
